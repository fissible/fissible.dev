---
// apps/site/src/components/ComingSoonPage.astro
import type { PaidProduct } from '../data/packages';
interface Props {
  product: PaidProduct;
  formspreeId: string;
  statusNote?: string;
}
const { product, formspreeId, statusNote } = Astro.props;
---
<main class="coming-soon-page">
  <header class="coming-soon-hero">
    <p class="coming-soon-label">Coming Soon</p>
    <h1>{product.name}</h1>
    <p class="coming-soon-tagline">{product.tagline}</p>
    <p class="coming-soon-description">{product.description}</p>
    {statusNote && <p class="coming-soon-status">{statusNote}</p>}
  </header>
  <section class="waitlist-section">
    <h2>Get notified at launch</h2>
    <form
      class="waitlist-form"
      action={`https://formspree.io/f/${formspreeId}`}
      method="POST"
    >
      <input type="email" name="email" placeholder="your@email.com" required />
      <input type="hidden" name="product" value={product.slug} />
      <button type="submit">Notify me</button>
    </form>
  </section>
</main>

<style>
.coming-soon-page { max-width: 640px; margin: 0 auto; padding: 5rem 2rem; text-align: center; }
.coming-soon-label { font-size: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; color: var(--accent); margin-bottom: 1rem; }
.coming-soon-hero h1 { font-size: 2.5rem; font-weight: 700; letter-spacing: -0.04em; margin-bottom: 0.5rem; }
.coming-soon-tagline { color: var(--text-muted); font-size: 1.1rem; margin-bottom: 1rem; }
.coming-soon-description { color: var(--text-muted); font-size: 0.95rem; max-width: 480px; margin: 0 auto 1.5rem; }
.coming-soon-status { font-size: 0.875rem; color: var(--accent); background: color-mix(in srgb, var(--accent) 10%, transparent); border: 1px solid color-mix(in srgb, var(--accent) 25%, transparent); border-radius: var(--radius); padding: 0.5rem 1rem; display: inline-block; margin-bottom: 1.5rem; }
.waitlist-section { margin-top: 2.5rem; }
.waitlist-section h2 { font-size: 0.875rem; font-weight: 600; color: var(--text-muted); margin-bottom: 1rem; }
.waitlist-form { justify-content: center; }
</style>
