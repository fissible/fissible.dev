---
// apps/site/src/components/ConvergeCTA.astro
import { paidProducts } from '../data/packages';
const station = paidProducts.find(p => p.slug === 'station')!;
---
<section class="converge-cta">
  <h2 class="converge-heading">If approval is mandatory, your CMS should enforce it.</h2>
  <p class="converge-sub">Join the launch list for Station. v1 focuses on enforced review, versioned publishing, scheduling, and multi-site isolation without the usual per-site CMS overhead.</p>
  <form
    class="waitlist-form converge-form"
    action={`https://formspree.io/f/${station.formspreeId}`}
    method="POST"
  >
    <input type="email" name="email" placeholder="Work email" required />
    <input type="hidden" name="product" value={station.slug} />
    <button type="submit">Request Access</button>
  </form>
  <div class="converge-actions">
    <a href="/station" class="btn-secondary">Read the Station Page</a>
  </div>
</section>

<style>
.converge-cta {
  padding: 4rem 2rem;
  text-align: center;
}
.converge-heading {
  font-size: 1.35rem;
  font-weight: 700;
  margin-bottom: 0.5rem;
}
.converge-sub {
  font-size: 0.9rem;
  color: var(--text-muted);
  margin-bottom: 1rem;
}
.converge-actions {
  display: flex;
  gap: 0.75rem;
  justify-content: center;
  flex-wrap: wrap;
}
.converge-form {
  justify-content: center;
  margin-bottom: 1rem;
}
</style>
