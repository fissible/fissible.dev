---
// apps/site/src/components/Hero.astro
import { paidProducts } from '../data/packages';
const station = paidProducts.find(p => p.slug === 'station')!;
---
<section class="hero">
  <div class="hero-copy">
    <p class="hero-brand">fissible station</p>
    <h1 class="hero-headline">The self-hosted CMS for teams that need approval before anything goes live.</h1>
    <p class="hero-clarifying">Drafts, review, scheduling, audit history, and tenant isolation built into the publishing path so mistakes do not reach production.</p>
    <div class="hero-proof">
      <span>Self-hosted</span>
      <span>Laravel + Filament</span>
      <span>One-time license</span>
    </div>
    <form
      class="waitlist-form hero-form"
      action={`https://formspree.io/f/${station.formspreeId}`}
      method="POST"
    >
      <input type="email" name="email" placeholder="Work email" required />
      <input type="hidden" name="product" value={station.slug} />
      <button type="submit">Join the Waitlist</button>
    </form>
    <p class="hero-form-note">Built for compliance-sensitive marketing, legal, editorial, and multi-site teams that need approval enforcement without per-site CMS multiplication.</p>
    <div class="hero-cta">
      <a href="/station" class="btn-secondary">See Station Details</a>
      <a href="#workflow" class="btn-secondary">See How It Works ↓</a>
    </div>
  </div>
</section>

<style>
.hero {
  padding: 5rem 2rem 4rem;
}
.hero-copy {
  max-width: 760px;
  margin: 0 auto;
  text-align: center;
}
.hero-brand {
  font-size: 0.7rem;
  text-transform: uppercase;
  letter-spacing: 0.15em;
  color: var(--accent);
  margin-bottom: 1rem;
}
.hero-headline {
  font-size: clamp(2rem, 5vw, 3.35rem);
  font-weight: 800;
  line-height: 1.15;
  letter-spacing: -0.03em;
  margin-bottom: 1rem;
  max-width: 820px;
  margin-inline: auto;
}
.hero-clarifying {
  font-size: 1.05rem;
  color: var(--text-muted);
  max-width: 620px;
  margin: 0 auto 1rem;
  line-height: 1.5;
}
.hero-proof {
  display: flex;
  justify-content: center;
  gap: 0.5rem;
  flex-wrap: wrap;
  margin-bottom: 1.25rem;
}
.hero-proof span {
  font-size: 0.78rem;
  font-weight: 600;
  color: var(--text-muted);
  border: 1px solid var(--border);
  border-radius: 999px;
  padding: 0.3rem 0.7rem;
  background: var(--bg-subtle);
}
.hero-form {
  justify-content: center;
  margin-bottom: 0.75rem;
}
.hero-form-note {
  font-size: 0.82rem;
  color: var(--text-muted);
  margin-bottom: 1.4rem;
}
.hero-cta {
  display: flex;
  gap: 0.75rem;
  justify-content: center;
  flex-wrap: wrap;
}
@media (max-width: 600px) {
  .hero {
    padding-top: 4rem;
  }
}
</style>
