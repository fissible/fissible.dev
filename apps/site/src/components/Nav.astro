---
// apps/site/src/components/Nav.astro
import { tuiPackages, phpPackages, paidProducts } from '../data/packages';
---
<nav class="nav">
  <a href="/" class="nav-logo">fissible</a>
  <div class="nav-links">
    <div class="nav-dropdown">
      <button class="nav-dropdown-toggle">TUI Suite</button>
      <div class="nav-dropdown-menu">
        {tuiPackages.map(p => <a href={`/${p.slug}`}>{p.name}</a>)}
      </div>
    </div>
    <div class="nav-dropdown">
      <button class="nav-dropdown-toggle">PHP Suite</button>
      <div class="nav-dropdown-menu">
        {phpPackages.map(p => <a href={`/${p.slug}`}>{p.name}</a>)}
      </div>
    </div>
    <div class="nav-dropdown">
      <button class="nav-dropdown-toggle">Coming Soon</button>
      <div class="nav-dropdown-menu">
        {paidProducts.map(p => <a href={`/${p.slug}`}>{p.name}</a>)}
      </div>
    </div>
    <a
      href="https://github.com/fissible"
      target="_blank"
      rel="noopener noreferrer"
      class="nav-github"
    >GitHub</a>
  </div>
</nav>
