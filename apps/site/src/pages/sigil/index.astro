---
import Layout from '../../layouts/Layout.astro';
import ComingSoonPage from '../../components/ComingSoonPage.astro';
import { paidProducts } from '../../data/packages';
const product = paidProducts.find(p => p.slug === 'sigil')!;
---
<Layout title={product.name} description={product.description}>
  <ComingSoonPage
    product={product}
    formspreeId={product.formspreeId}
    statusNote="sigil v1 is complete. Available to purchase the moment our store opens."
  />
</Layout>
